    function toggleClip(){
      clipEl.classList.toggle('revealed');
      setTimeout(function(){ clipEl.classList.toggle('revealed'); }, 1200);
    }
    setTimeout(toggleClip, 400);
    setInterval(toggleClip, 2800);

    // Manual trigger button
    document.getElementById('triggerAnims').addEventListener('click', function(){
      document.querySelectorAll('.anim-appear, .anim-line').forEach(function(el){
        el.classList.remove('running');
        void el.offsetWidth; // reflow
        el.classList.add('running');
      });
    });
  })();
  </script>

  <table class="usage-table">
    <thead><tr><th>Pattern</th><th>Keyframe / technique</th><th>Use when</th></tr></thead>
    <tbody>
      <tr><td>Draw-on loop</td><td><code>draw-path</code> · 3s infinite · stroke-dashoffset</td><td>Hero or How I Work SVG marks. Continuous ambient motion only — never on small UI icons.</td></tr>
      <tr><td>Staggered appear</td><td><code>appear-fade</code> · opacity 0→1 + translateY(8→0) · IntersectionObserver</td><td>SVG diagram elements, architecture nodes. Trigger via <code>.running</code> class on scroll.</td></tr>
      <tr><td>Line draw</td><td><code>line-draw</code> · stroke-dashoffset 200→0 · triggered</td><td>Connector lines in architecture/flow diagrams. Pair with staggered appear on nodes.</td></tr>
      <tr><td>Ripple / pulse</td><td><code>ripple-out</code> · r 4→32 · opacity .7→0 · 2s infinite · stagger offset</td><td>Live / active state indicator. Two rings, offset 0.6s. Never purely decorative.</td></tr>
      <tr><td>Clip reveal</td><td><code>clip-path inset(10% 6%) → inset(0%)</code> · 1.1s cubic-bezier · IntersectionObserver</td><td>Full-width image reveals on scroll. Threshold 0.08.</td></tr>
    </tbody>
  </table>

  <table class="usage-table" style="margin-top:2px;">
    <thead><tr><th>Rule</th><th>Requirement</th></tr></thead>
    <tbody>
      <tr><td>Color</td><td>Stroke/fill must use system tokens only: --black, --white, --mid, or rgba variants. No hues.</td></tr>
      <tr><td>Stroke weight</td><td>1px for secondary/structural lines. 1.5px for primary paths. Never heavier than 2px.</td></tr>
      <tr><td>Fill</td><td>Prefer strokes over fills. Filled shapes use --black, --mid, or rgba(--white). No solid color fills.</td></tr>
      <tr><td>Border radius</td><td>Always 0 in SVG shapes (rx="0"). Consistent with the rest of the system.</td></tr>
      <tr><td>Easing</td><td>ease or ease-in-out for all path animations. cubic-bezier(0.16,1,0.3,1) for reveals.</td></tr>
      <tr><td>Duration</td><td>Triggered: 0.5–0.75s per element. Looping ambient: 2–3s. Never under 0.4s.</td></tr>
      <tr><td>Stagger delay</td><td>0.1–0.2s between sequential elements. Use CSS <code>animation-delay</code> or <code>--d</code> custom property.</td></tr>
      <tr><td>Play state</td><td>Triggered animations start paused. Add <code>.running</code> class via IntersectionObserver — never autoplay on load.</td></tr>
      <tr><td>Typographic first</td><td>→ · — ↗︎ ↓ ← are preferred over SVG for inline directional marks. Only use SVG when the icon communicates something a glyph cannot.</td></tr>
      <tr><td>No icon fonts</td><td>Never use FontAwesome, Material Icons, or any icon font. Inline SVG only.</td></tr>
      <tr><td>No emoji</td><td>Never. Not in content, not as decorative marks, not in any output.</td></tr>
      <tr><td>No Lottie / GreenSock</td><td>CSS animation only. No third-party animation libraries in custom HTML widgets.</td></tr>
      <tr><td>Multicolor prohibited</td><td>Icons with more than one color are never used. Monochromatic only.</td></tr>
    </tbody>
  </table>
</section>

<!-- RULES -->
<section class="ds-section" id="rules">
  <div class="ds-eyebrow">09 · Rules</div>
  <h2><strong>Design</strong> Rules</h2>

  <table class="usage-table">
    <thead><tr><th>Rule</th><th>Requirement</th></tr></thead>
    <tbody>
      <tr><td>Border radius</td><td>Always 0. No rounded corners anywhere in this system.</td></tr>
      <tr><td>Grid gaps</td><td>Always 2px. Set gap:2px + background:var(--rule) on parent element.</td></tr>
      <tr><td>Colors</td><td>6 tokens only. No new colors without direction. No hues of any kind.</td></tr>
      <tr><td>Fonts</td><td>EB Garamond + Outfit only. No third font ever.</td></tr>
      <tr><td>Uppercase text</td><td>Outfit only. Never EB Garamond in uppercase — ever.</td></tr>
      <tr><td>H2 / H3 fonts</td><td>EB Garamond only. Never Outfit on section headings.</td></tr>
      <tr><td>Serif in all-caps</td><td>Never. Prohibited even if explicitly requested in error.</td></tr>
      <tr><td>Hover — buttons</td><td>opacity 0.7 + translateY(-1px). No color/background change.</td></tr>
      <tr><td>Hover — cards</td><td>background → --off. Accent bar scaleX(0→1) on ::after if used.</td></tr>
      <tr><td>Hover — links</td><td>opacity 0.5 globally. Inline links: opacity 0.6.</td></tr>
      <tr><td>Images</td><td>Never crop or force into fixed aspect ratios. Build layout around natural dimensions.</td></tr>
      <tr><td>Reveal animation</td><td>opacity 0→1 + translateY(22px→0), 0.75s ease. IntersectionObserver only.</td></tr>
      <tr><td>Nav behavior</td><td>Transparent until scroll > 60px, then background: rgba(13,13,11,.94) + backdrop-filter: blur(12px).</td></tr>
      <tr><td>Print backgrounds</td><td>Use pure #ffffff (not --white) for page backgrounds in print/PDF documents.</td></tr>
      <tr><td>Print overflow</td><td>height: 11in + overflow: hidden on .page divs. No content past page boundary.</td></tr>
      <tr><td>Elementor CSS</td><td>Deliver via WPCode footer (after Elementor stylesheet). Scope to specific element IDs where possible.</td></tr>
      <tr><td>Elementor mobile edits</td><td>Mobile view changes apply globally. Use WPCode CSS overrides, not Elementor mobile panel.</td></tr>
      <tr><td>Duplicate content</td><td>Never duplicate content on the same page. One instance per piece of information.</td></tr>
      <tr><td>Emojis / icons</td><td>None. Use typographic marks (—, ·, →) or monochromatic SVG only if essential.</td></tr>
      <tr><td>Blog nav</td><td>Blog page must not appear in site navigation until fully ready and launched.</td></tr>
      <tr><td>Section stacking</td><td>Never stack two dark (--black) sections. Max one dark section per page.</td></tr>
    </tbody>
  </table>
</section>

