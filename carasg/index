<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Cara A. Brown — Design System Reference</title>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root {
  --black: #0d0d0b;
  --white: #f6f5f1;
  --off:   #efede8;
  --mid:   #888680;
  --rule:  #dddad3;
  --ink:   #1e1e1c;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Outfit', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  color: var(--ink);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
}

/* ── DOC CHROME ─────────────────────────────── */
.doc-header {
  background: var(--black);
  color: var(--white);
  padding: 56px 60px 52px;
  border-bottom: 3px solid var(--mid);
}
.doc-header .label {
  font-size: .6rem; font-weight: 600;
  letter-spacing: .38em; text-transform: uppercase;
  color: rgba(246,245,241,.38);
  margin-bottom: 10px;
}
.doc-header h1 {
  font-family: 'Outfit', sans-serif;
  font-size: 2.2rem; font-weight: 300;
  letter-spacing: -.02em; color: var(--white);
}
.doc-header h1 strong { font-weight: 600; }
.doc-header .sub {
  margin-top: 10px;
  font-size: .82rem; color: rgba(246,245,241,.42); font-weight: 300;
}

.doc-nav {
  background: var(--off);
  border-bottom: 1px solid var(--rule);
  padding: 0 60px;
  display: flex; gap: 0; overflow-x: auto;
  position: sticky; top: 0; z-index: 100;
}
.doc-nav a {
  display: block; padding: 14px 18px;
  font-size: .62rem; font-weight: 600;
  letter-spacing: .16em; text-transform: uppercase;
  color: var(--mid); text-decoration: none;
  white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: color .2s, border-color .2s;
}
.doc-nav a:hover { color: var(--black); border-bottom-color: var(--black); }

.doc-body { max-width: 1100px; margin: 0 auto; padding: 0 60px 100px; }

/* ── SECTIONS ───────────────────────────────── */
.ds-section {
  padding: 80px 0 60px;
  border-bottom: 1px solid var(--rule);
}
.ds-section:last-child { border-bottom: none; }
.ds-eyebrow {
  font-size: .58rem; font-weight: 600;
  letter-spacing: .36em; text-transform: uppercase;
  color: var(--mid); margin-bottom: 6px;
}
.ds-section h2 {
  font-family: 'Outfit', sans-serif;
  font-size: 1.6rem; font-weight: 300;
  letter-spacing: -.02em; color: var(--ink);
  margin-bottom: 40px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--rule);
}
.ds-section h2 strong { font-weight: 600; }
.token-note {
  font-size: .78rem; color: var(--mid);
  line-height: 1.7; margin-bottom: 36px;
  max-width: 680px;
}
code {
  font-family: 'Courier New', monospace;
  font-size: .78rem;
  background: var(--off);
  border: 1px solid var(--rule);
  padding: 2px 7px;
  color: var(--ink);
}

/* ── COLOR ──────────────────────────────────── */
.swatch-row { display: flex; gap: 2px; flex-wrap: wrap; margin-bottom: 36px; }
.swatch { display: flex; flex-direction: column; min-width: 155px; flex: 1; }
.swatch-chip { height: 80px; border: 1px solid rgba(0,0,0,.06); }
.swatch-info {
  background: var(--off);
  padding: 12px 14px;
  border: 1px solid var(--rule);
  border-top: none;
}
.swatch-name {
  font-size: .68rem; font-weight: 600; letter-spacing: .06em;
  color: var(--ink); display: block; margin-bottom: 2px;
}
.swatch-token {
  font-family: 'Courier New', monospace;
  font-size: .68rem; color: var(--mid); display: block; margin-bottom: 2px;
}
.swatch-hex {
  font-family: 'Courier New', monospace;
  font-size: .68rem; color: var(--mid); display: block;
}
.swatch-use {
  font-size: .68rem; color: var(--mid);
  margin-top: 4px; display: block; line-height: 1.4;
}

/* ── TABLE ──────────────────────────────────── */
.usage-table {
  width: 100%; border-collapse: collapse;
  font-size: .82rem; margin-bottom: 32px;
}
.usage-table th {
  text-align: left; padding: 10px 16px;
  background: var(--off);
  font-size: .6rem; font-weight: 600;
  letter-spacing: .14em; text-transform: uppercase;
  color: var(--mid); border: 1px solid var(--rule);
}
.usage-table td {
  padding: 12px 16px;
  border: 1px solid var(--rule);
  color: var(--ink); vertical-align: top; line-height: 1.6;
}
.usage-table td:first-child {
  font-family: 'Courier New', monospace;
  font-size: .75rem; color: var(--ink);
  white-space: nowrap; width: 200px;
}
.usage-table tr:nth-child(even) td { background: var(--off); }

/* ── TYPE SPECIMENS ─────────────────────────── */
.type-specimen {
  background: var(--white);
  border: 1px solid var(--rule);
  padding: 40px 44px;
  margin-bottom: 2px;
}
.type-meta {
  font-size: .6rem; font-weight: 600;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--mid); margin-bottom: 14px;
}
.type-note {
  font-size: .68rem; color: var(--mid);
  margin-top: 12px; line-height: 1.5;
}

/* ── SPACING ────────────────────────────────── */
.space-row {
  display: flex; gap: 24px; flex-wrap: wrap;
  margin-bottom: 36px; align-items: flex-end;
}
.space-item { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.space-bar { background: var(--mid); width: 40px; }
.space-val { font-size: .65rem; font-weight: 600; color: var(--ink); }
.space-label { font-size: .6rem; color: var(--mid); text-align: center; }

/* ── BUTTONS ────────────────────────────────── */
.demo-block { padding: 40px; }
.demo-label {
  font-size: .6rem; font-weight: 600;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--mid); margin-bottom: 16px;
}
.btn-row { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
.btn {
  font-family: 'Outfit', sans-serif;
  font-size: .78rem; font-weight: 500;
  letter-spacing: .2em; text-transform: uppercase;
  padding: 18px 44px; text-decoration: none;
  display: inline-block; border-radius: 0;
  transition: opacity .3s, transform .2s;
  border: 1px solid transparent;
}
.btn:hover { opacity: .7; transform: translateY(-1px); }
.btn-dark   { background: var(--black); color: var(--white); }
.btn-outline { background: transparent; color: var(--ink); border-color: var(--ink); }
.btn-white  { background: var(--white); color: var(--black); }
.btn-outline-white { background: transparent; color: var(--white); border-color: var(--white); }

/* ── SECTION PATTERNS ───────────────────────── */
.section-pattern {
  padding: 24px 36px;
  font-size: .72rem; font-weight: 500;
  letter-spacing: .1em; text-transform: uppercase;
  margin-bottom: 2px;
}
.grid-demo { display: flex; gap: 2px; margin-bottom: 2px; }
.grid-cell {
  flex: 1; padding: 32px 28px;
  background: var(--off); border: 1px solid var(--rule);
  font-size: .78rem; color: var(--mid);
  font-style: italic;
}
.grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; }

/* ── COMPONENT DEMOS ────────────────────────── */
.praise-demo {
  background: var(--off);
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 0; margin-bottom: 32px;
}
.praise-card {
  padding: 40px 36px;
  border-right: 1px solid var(--rule);
}
.praise-card:last-child { border-right: none; }
.praise-quote {
  font-family: 'EB Garamond', serif;
  font-size: 1.1rem; font-style: italic;
  line-height: 1.65; color: var(--ink); margin-bottom: 20px;
}
.praise-attr {
  font-size: .65rem; font-weight: 500;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--mid);
}

.pullquote-demo {
  background: var(--off);
  padding: 48px 56px;
  margin-bottom: 32px;
}
.pullquote-demo p {
  font-family: 'EB Garamond', serif;
  font-size: clamp(1.5rem,2.4vw,2.2rem);
  font-style: italic; line-height: 1.3;
  color: var(--black); letter-spacing: -0.01em;
  border-left: 3px solid var(--black);
  padding-left: 36px; margin: 0;
}

.arch-demo {
  background: var(--off);
  padding: 44px 52px;
  display: grid; grid-template-columns: 200px 1fr auto;
  gap: 0 52px; align-items: center;
  margin-bottom: 32px;
}
.arch-type {
  font-size: .65rem; font-weight: 500;
  letter-spacing: .22em; text-transform: uppercase;
  color: var(--mid); line-height: 1.6;
}
.arch-text {
  font-family: 'EB Garamond', serif;
  font-size: 1.05rem; font-style: italic;
  line-height: 1.65; color: var(--ink); margin: 0;
}
.arch-link {
  font-size: .75rem; font-weight: 500;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--black); text-decoration: none;
  border-bottom: 1px solid var(--black);
  padding-bottom: 2px; white-space: nowrap;
}

.stat-demo {
  background: var(--black); padding: 40px 48px;
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 2px; margin-bottom: 32px;
}
.stat-cell {
  padding: 28px 24px;
  background: var(--black);
  border-right: 1px solid rgba(255,255,255,.08);
}
.stat-cell:last-child { border-right: none; }
.stat-n {
  font-family: 'EB Garamond', serif;
  font-size: clamp(2rem,3vw,2.8rem);
  font-weight: 400; color: var(--white);
  line-height: 1; display: block; margin-bottom: 12px;
}
.stat-l {
  font-size: .78rem; color: rgba(246,245,241,.5);
  line-height: 1.5; display: block;
}

.context-strip-demo {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 0; border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  margin-bottom: 32px;
}
.ctx-cell {
  padding: 28px 24px 28px 0;
  border-right: 1px solid var(--rule);
  padding-right: 32px;
}
.ctx-cell:first-child { padding-left: 0; }
.ctx-cell:last-child { border-right: none; }
.ctx-label {
  font-size: .5rem; font-weight: 500;
  letter-spacing: .22em; text-transform: uppercase;
  color: var(--mid); display: block; margin-bottom: 10px;
}
.ctx-value {
  font-size: .88rem; line-height: 1.5;
}

.proj-card-demo {
  position: relative; height: 280px; overflow: hidden; display: block;
  text-decoration: none;
}
.proj-card-bg {
  position: absolute; inset: 0;
  background: #c8c4bc;
  filter: grayscale(60%) brightness(0.55);
}
.proj-card-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(13,13,11,.92) 0%, rgba(13,13,11,.25) 100%);
  z-index: 1;
}
.proj-card-content {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 2;
  padding: 32px;
}
.proj-tag {
  font-size: .65rem; font-weight: 500;
  letter-spacing: .22em; text-transform: uppercase;
  color: rgba(246,245,241,.5); display: block; margin-bottom: 10px;
}
.proj-title {
  font-family: 'EB Garamond', serif;
  font-size: 1.5rem; font-weight: 400;
  line-height: 1.2; color: var(--white); display: block;
}

.cta-demo {
  padding: 64px 48px; text-align: center;
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  margin-bottom: 32px;
}
.cta-demo h3 {
  font-family: 'EB Garamond', serif;
  font-size: clamp(1.5rem,2.5vw,2.1rem);
  font-weight: 400; line-height: 1.2;
  letter-spacing: -.015em;
  max-width: 500px; margin: 0 auto 28px; color: var(--black);
}

.footer-demo {
  background: var(--black); margin-bottom: 32px;
}
.footer-top {
  border-bottom: 1px solid rgba(255,255,255,.1);
  padding: 28px 48px;
  display: flex; align-items: center; justify-content: space-between;
}
.footer-brand {
  font-size: .65rem; font-weight: 500;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--white);
}
.footer-avail {
  font-size: .62rem; font-weight: 500;
  letter-spacing: .2em; text-transform: uppercase;
  color: rgba(255,255,255,.45);
  border: 1px solid rgba(255,255,255,.2); padding: 7px 14px;
}
.footer-tiles {
  display: grid; grid-template-columns: repeat(4,1fr);
}
.footer-tile {
  padding: 36px 32px;
  border-right: 1px solid rgba(255,255,255,.08);
  display: flex; flex-direction: column; gap: 10px;
}
.footer-tile:last-child { border-right: none; }
.tile-verb {
  font-size: .6rem; font-weight: 500;
  letter-spacing: .28em; text-transform: uppercase;
  color: rgba(255,255,255,.35);
}
.tile-lbl {
  font-family: 'EB Garamond', serif;
  font-size: 1.3rem; font-weight: 400; color: var(--white);
}
.tile-det { font-size: .72rem; color: rgba(255,255,255,.4); line-height: 1.5; }
.tile-act {
  font-size: .62rem; font-weight: 500;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--white); margin-top: 8px;
  padding-top: 12px; border-top: 1px solid rgba(255,255,255,.1);
}
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,.08);
  padding: 16px 48px;
  display: flex; justify-content: space-between; align-items: center;
}
.footer-bottom span {
  font-size: .62rem; letter-spacing: .14em;
  text-transform: uppercase; color: rgba(255,255,255,.2);
}
</style>
</head>
