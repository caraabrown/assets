<script>
// Variant A demo
(function(){
  var track = document.getElementById('demoTrackA');
  var prev  = document.getElementById('demoPrevA');
  var next  = document.getElementById('demoNextA');
  var count = document.getElementById('demoCountA');
  var slides = track.querySelectorAll('.ca-slide');
  var total = slides.length, idx = 0;
  function go(n){
    idx = Math.max(0, Math.min(total-1, n));
    track.style.transform = 'translateX('+(-idx*100)+'%)';
    if(count) count.textContent = (idx+1)+' / '+total;
    prev.disabled = idx === 0;
    next.disabled = idx === total-1;
  }
  prev.addEventListener('click', function(){ go(idx-1); });
  next.addEventListener('click', function(){ go(idx+1); });
  var sx=0;
  track.addEventListener('touchstart',function(e){sx=e.touches[0].clientX;},{passive:true});
  track.addEventListener('touchend',function(e){var dx=e.changedTouches[0].clientX-sx;if(Math.abs(dx)>45)dx<0?go(idx+1):go(idx-1);},{passive:true});
  go(0);
})();

// Variant B demo
(function(){
  var track = document.getElementById('demoTrackB');
  var prev  = document.getElementById('demoPrevB');
  var next  = document.getElementById('demoNextB');
  var count = document.getElementById('demoCountB');
  var dotsWrap = document.getElementById('demoDotsB');
  var slides = track.querySelectorAll('.cb-slide');
  var total = slides.length, idx = 0;
  var dots = Array.from(slides).map(function(_,i){
    var b = document.createElement('button');
    b.className = 'cb-dot-demo';
    b.type = 'button';
    b.setAttribute('aria-label','Go to slide '+(i+1));
    b.addEventListener('click',function(){ go(i); });
    dotsWrap.appendChild(b);
    return b;
  });
  function go(n){
    idx = Math.max(0, Math.min(total-1, n));
    track.style.transform = 'translateX('+(-idx*100)+'%)';
    dots.forEach(function(d,i){ d.setAttribute('aria-current', i===idx?'true':'false'); });
    if(count) count.textContent = (idx+1)+' / '+total;
    prev.disabled = idx===0;
    next.disabled = idx===total-1;
  }
  prev.addEventListener('click',function(){ go(idx-1); });
  next.addEventListener('click',function(){ go(idx+1); });
  var sx=0;
  track.addEventListener('touchstart',function(e){sx=e.touches[0].clientX;},{passive:true});
  track.addEventListener('touchend',function(e){var dx=e.changedTouches[0].clientX-sx;if(Math.abs(dx)>45)dx<0?go(idx+1):go(idx-1);},{passive:true});
  go(0);
})();
